{
  "name": "@kb-labs/platform-client",
  "version": "1.5.0",
  "description": "Unified client SDK for KB Labs platform. Zero dependencies. Access LLM, Cache, VectorStore, Analytics, and any adapter through a single client.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "lint": "eslint . --ignore-pattern 'dist/**' --ignore-pattern 'coverage/**'",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@kb-labs/devkit": "^1.2.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
